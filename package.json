{
  "name": "cuerates",
  "version": "1.0.0",
  "description": "Experience Cinema Together",
  "private": true,
  "main": "build/electron.js",
  "homepage": "./",
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "app-builder-bin": "^5.0.0-alpha.10",
    "axios": "^1.6.7",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.36.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.18",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.0",
    "redux": "^4.2.1",
    "socket.io-client": "^4.8.3",
    "universalify": "^2.0.1",
    "webtorrent": "^1.9.7"
  },
  "scripts": {
    "start": "set \"NODE_OPTIONS=--max-old-space-size=4096\" && react-scripts start",
    "build": "react-scripts build",
    "server": "npm run dev --prefix server",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "electron:dev": "electron public/electron.js",
    "electron:build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 PUBLIC_URL=. react-scripts build && copy /y public\\electron.js build\\ && copy /y public\\preload.js build\\ && copy /y public\\torrent-server.js build\\ && electron-builder --win --publish=never -c.npmRebuild=false",
    "electron:publish": "cross-env NODE_OPTIONS=--max-old-space-size=4096 PUBLIC_URL=. react-scripts build && copy /y public\\electron.js build\\ && copy /y public\\preload.js build\\ && copy /y public\\torrent-server.js build\\ && electron-builder --win --publish=always -c.npmRebuild=false"
  },
  "build": {
    "appId": "com.cinelog.desktop",
    "productName": "CineLog",
    "extends": null,
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "directories": {
      "buildResources": "public",
      "output": "release24"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "RagedAbhi",
        "repo": "cinelog"
      }
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "json-server": "^0.17.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "wait-on": "^9.0.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
